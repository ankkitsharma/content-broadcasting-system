## Example env file for Docker Compose (prod)
## Usage:
##   cp .env.docker.example .env
##   docker compose -f docker-compose.prod.yml up -d --build
##
## Notes:
## - In Docker Compose, the Postgres host is the service name: `db` (not `localhost`).
## - Values here are examples; change secrets before deployment.

PORT=3000

# Public base URL for links & Swagger "Try it out".
# Set this to your VPS domain (or IP) in production.
PUBLIC_BASE_URL="http://localhost:3000"

# Postgres (used by the `db` service; compose file has fallbacks)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=content_broadcasting

# Prisma / API connection string (used by the `api` service; required in prod compose)
DATABASE_URL="postgresql://postgres:postgres@db:5432/content_broadcasting?schema=public"

# Auth (required)
JWT_SECRET="change_me_change_me_change_me"

# Uploads / rotation
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=10
DEFAULT_ROTATION_MINUTES=5

