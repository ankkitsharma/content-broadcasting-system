PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/content_broadcasting?schema=public"
JWT_SECRET="change_me_change_me_change_me"
PUBLIC_BASE_URL="http://localhost:3000"
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=10
DEFAULT_ROTATION_MINUTES=5
REDIS_URL="redis://redis:6379"
LIVE_CONTENT_CACHE_TTL_SECONDS=15
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=60

# Storage
STORAGE_PROVIDER="local" # "local" | "s3"

# Cloudflare R2 (S3-compatible)
# - Create an R2 bucket and an R2 API token (S3 credentials).
# - Endpoint format: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="content-broadcasting"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public bucket/base URL used for serving objects (public bucket route).
# Example: https://pub-<hash>.r2.dev/<bucket>  OR your custom domain.
S3_PUBLIC_BASE_URL="https://<public-base>/<bucket>"
S3_FORCE_PATH_STYLE=true
